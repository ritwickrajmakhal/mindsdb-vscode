{
  "name": "mindsdb-vscode",
  "displayName": "MindsDB for VS Code",
  "description": "MindsDB is a popular open-source query engine for AI analytics, powering AI agents that need to answer questions directly from databases, data warehouses, and applications, with no ETL required.",
  "version": "0.0.2",
  "repository": {
    "url": "https://github.com/ritwickrajmakhal/mindsdb-vscode"
  },
  "icon": "resources/mindsdb-icon-128x128.png",
  "publisher": "ritwickrajmakhal",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mindsdb-explorer",
          "title": "MindsDB",
          "icon": "resources/mindsdb-icon.svg"
        },
        {
          "id": "mindsdb-chat-container",
          "title": "MindsDB Chat",
          "icon": "resources/mindsdb-chat-icon.png"
        }
      ]
    },
    "views": {
      "mindsdb-explorer": [
        {
          "id": "mindsdb-system",
          "name": "System",
          "icon": "resources/mindsdb-icon.svg"
        },
        {
          "id": "mindsdb-projects",
          "name": "Projects",
          "icon": "resources/mindsdb-icon.svg"
        },
        {
          "id": "mindsdb-datasources",
          "name": "Datasources",
          "icon": "resources/mindsdb-icon.svg"
        }
      ],
      "mindsdb-chat-container": [
        {
          "type": "webview",
          "id": "mindsdb.chatView",
          "name": "MindsDB Chat",
          "icon": "resources/mindsdb-chat-icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "mindsdb.addConnection",
        "title": "Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "mindsdb.deleteConnection",
        "title": "Disconnect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "mindsdb.refreshConnections",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mindsdb.newNotebook",
        "title": "New MindsDB Notebook",
        "shortTitle": "New Notebook"
      },
      {
        "command": "mindsdb.uploadFile",
        "title": "Upload File",
        "icon": "$(add)"
      },
      {
        "command": "mindsdb.deleteProjectItem",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "mindsdb.deleteProject",
        "title": "Delete Project",
        "icon": "$(trash)"
      },
      {
        "command": "mindsdb.createProject",
        "title": "Create Project",
        "icon": "$(add)"
      },
      {
        "command": "mindsdb.deleteDatasource",
        "title": "Delete Datasource",
        "icon": "$(trash)"
      },
      {
        "command": "mindsdb.deleteFile",
        "title": "Delete File",
        "icon": "$(trash)"
      },
      {
        "command": "mindsdb.createAgent",
        "title": "Create Agent",
        "icon": "$(add)"
      },
      {
        "command": "mindsdb.createJob",
        "title": "Create Job",
        "icon": "$(add)"
      },
      {
        "command": "mindsdb.createKnowledgeBase",
        "title": "Create Knowledge Base",
        "icon": "$(add)"
      },
      {
        "command": "mindsdb.createModel",
        "title": "Create Model",
        "icon": "$(add)"
      },
      {
        "command": "mindsdb.createView",
        "title": "Create View",
        "icon": "$(add)"
      },
      {
        "command": "mindsdb.showIntegrations",
        "title": "Browse Integrations",
        "icon": "$(search)"
      },
      {
        "command": "mindsdb.showDocumentation",
        "title": "Help",
        "icon": "$(question)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mindsdb.addConnection",
          "when": "view == mindsdb-system && !mindsdb.connected",
          "group": "navigation"
        },
        {
          "command": "mindsdb.deleteConnection",
          "when": "view == mindsdb-system && mindsdb.connected",
          "group": "navigation"
        },
        {
          "command": "mindsdb.refreshConnections",
          "when": "view == mindsdb-system",
          "group": "navigation"
        },
        {
          "command": "mindsdb.createProject",
          "when": "view == mindsdb-projects",
          "group": "navigation"
        },
        {
          "command": "mindsdb.showIntegrations",
          "when": "view == mindsdb-datasources",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "mindsdb.deleteConnection",
          "when": "viewItem == connection",
          "group": "inline"
        },
        {
          "command": "mindsdb.deleteProjectItem",
          "when": "viewItem == project-item",
          "group": "inline"
        },
        {
          "command": "mindsdb.deleteProjectItem",
          "when": "viewItem == project-item",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.deleteProject",
          "when": "viewItem == project-deletable",
          "group": "inline"
        },
        {
          "command": "mindsdb.deleteProject",
          "when": "viewItem == project-deletable",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.showDocumentation",
          "when": "viewItem == project || viewItem == project-deletable",
          "group": "2_help"
        },
        {
          "command": "mindsdb.deleteDatasource",
          "when": "viewItem == database-deletable",
          "group": "inline"
        },
        {
          "command": "mindsdb.deleteDatasource",
          "when": "viewItem == database-deletable",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.showDocumentation",
          "when": "viewItem == database || viewItem == database-deletable || viewItem == database-files || viewItem == file-table",
          "group": "2_help"
        },
        {
          "command": "mindsdb.uploadFile",
          "when": "viewItem == database-files",
          "group": "inline"
        },
        {
          "command": "mindsdb.uploadFile",
          "when": "viewItem == database-files",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.deleteFile",
          "when": "viewItem == file-table",
          "group": "inline"
        },
        {
          "command": "mindsdb.deleteFile",
          "when": "viewItem == file-table",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.createAgent",
          "when": "viewItem == project-folder-agents",
          "group": "inline"
        },
        {
          "command": "mindsdb.createAgent",
          "when": "viewItem == project-folder-agents",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.createJob",
          "when": "viewItem == project-folder-jobs",
          "group": "inline"
        },
        {
          "command": "mindsdb.createJob",
          "when": "viewItem == project-folder-jobs",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.createKnowledgeBase",
          "when": "viewItem == project-folder-knowledge_bases",
          "group": "inline"
        },
        {
          "command": "mindsdb.createKnowledgeBase",
          "when": "viewItem == project-folder-knowledge_bases",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.createModel",
          "when": "viewItem == project-folder-models",
          "group": "inline"
        },
        {
          "command": "mindsdb.createModel",
          "when": "viewItem == project-folder-models",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.createView",
          "when": "viewItem == project-folder-views",
          "group": "inline"
        },
        {
          "command": "mindsdb.createView",
          "when": "viewItem == project-folder-views",
          "group": "1_modification"
        },
        {
          "command": "mindsdb.showDocumentation",
          "when": "viewItem =~ /project-folder-.*/ || viewItem == project-item",
          "group": "2_help"
        }
      ],
      "commandPalette": [
        {
          "command": "mindsdb.addConnection"
        },
        {
          "command": "mindsdb.newNotebook"
        }
      ]
    },
    "notebooks": [
      {
        "type": "mindsdb-notebook",
        "displayName": "MindsDB Notebook",
        "selector": [
          {
            "filenamePattern": "*.mindsdb"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "marked": "^17.0.4",
    "mindsdb-js-sdk": "^2.3.2"
  }
}
